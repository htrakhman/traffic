{
  "functions": {
    "api/chat.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/checkout-notify.ts": {
      "maxDuration": 15
    },
    "api/create-membership-checkout.ts": {
      "maxDuration": 15
    },
    "api/membership-complete.ts": {
      "maxDuration": 15
    },
    "api/membership-sync.ts": {
      "maxDuration": 15
    },
    "api/stripe-portal.ts": {
      "maxDuration": 15
    }
  },
  "redirects": [
    { "source": "/guides", "destination": "/blog", "permanent": true },
    { "source": "/guides/:slug", "destination": "/blog/:slug", "permanent": true }
  ],
  "rewrites": [
    {
      "source": "/roads-api/:path*",
      "destination": "https://roads.googleapis.com/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
