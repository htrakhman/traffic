VITE_ANTHROPIC_API_KEY=your_api_key_here

# Google Maps (browser): used by Job Planner polygon drawing. Copy to `.env` — never commit real keys.
# In Google Cloud: enable Maps JavaScript API; enable Geocoding API for reverse-geocode of the zone centroid.
# Restrict this key to HTTP referrers (localhost + your production origins); VITE_* values ship in the client bundle.
VITE_GOOGLE_MAPS_API_KEY=
