# /api/chat — SERVER-ONLY (Vercel serverless or Netlify Function). Never VITE_*.
#
# The proxy tries providers in CHAT_AI_FALLBACK_ORDER (default: gemini,openai,perplexity) and uses the first
# key that is set. Add at least one of:
#
# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Optional overrides:
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_CHAT_MODEL=gpt-4o-mini
#
# Gemini (Google AI Studio) — https://aistudio.google.com/app/apikey — alias: GOOGLE_AI_API_KEY
GEMINI_API_KEY=
#
# Perplexity (OpenAI-compatible) — https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=
# PERPLEXITY_CHAT_MODEL=sonar
#
# Comma-separated preference / fallback chain, e.g. gemini,openai or openai,perplexity
# CHAT_AI_FALLBACK_ORDER=gemini,openai,perplexity
#
# Local: use `vercel dev` from the repo root so `/api/chat` is served; plain `vite` does not run serverless routes.

# --- Stripe membership ($150/mo subscription) — server-only; never VITE_* ---
# Same secret key pattern as other projects: Dashboard → Developers → API keys → Secret key.
STRIPE_SECRET_KEY=
# Product → recurring Price (monthly $150). Price ID (starts with price_).
STRIPE_MEMBERSHIP_PRICE_ID=price_1SkHtfAPW7d3HCmzQkHLsTnh
# Optional. Canonical public URL for Checkout return links (e.g. https://trafficcontrolrental.com).
# If unset, Vercel uses VERCEL_URL; Netlify can set URL in the UI; local default is http://localhost:3000
# SITE_URL=

# --- Checkout notification (POST /api/checkout-notify) — server-only; never VITE_* ---
# Resend — https://resend.com/api-keys — used to email you when someone submits checkout.
RESEND_API_KEY=
# Comma-separated inboxes (e.g. haroldtrakhman@gmail.com)
CHECKOUT_NOTIFY_TO=
# Optional. For production, use a verified domain in Resend, e.g. "Traffic Control Rental <orders@yourdomain.com>"
# CHECKOUT_EMAIL_FROM=Traffic Control Rental <onboarding@resend.dev>

# Client-side flag: set to "true" to force the AI UI into demo/offline mode without calling /api/chat.
# Useful for previews / screenshots where you don't want to consume API credits.
# VITE_AI_DEMO_MODE=false

# Google Maps Platform (browser): one key can back many enabled APIs — turn each on in Cloud Console → APIs & Services → Library,
# then under Credentials → your key → API restrictions, allow only what this app (or your backend) needs.
#
# Used by this repo today:
#   - Maps JavaScript API (map + drawing + advanced markers)
#   - Geocoding API (reverse-geocode of work-zone centroid)
#   - Places API (place autocomplete / session suggestions in the map search box)
#
# PostHog (product analytics) — https://posthog.com — Project settings → Project API key.
# Without VITE_PUBLIC_POSTHOG_TOKEN the app runs normally but sends no PostHog events.
# VITE_PUBLIC_POSTHOG_TOKEN=phc_xxxxxxxx
# US (default in code if host omitted): https://us.i.posthog.com
# EU: https://eu.i.posthog.com
# VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Posted speed near the map crosshair / work zone:
#   - Roads API must be enabled on the key. Calls use same-origin `/roads-api/*` (Vite dev/preview proxy, or vercel.json / netlify.toml in repo).
#   - Google “Speed Limits” often needs an Asset Tracking license; if Google returns nothing, the app falls back to OpenStreetMap maxspeed.
#   - Override base URL only if you proxy Roads yourself: VITE_ROADS_API_BASE=https://your-backend.example.com/roads/v1
#   - Routes API / Directions API / Distance Matrix
#   - Places API (details, autocomplete)
#   - Street View Static API / Street View metadata
#   - Air Quality API / Pollen API (environmental layers — typically REST; consider a backend proxy so the key is not public)
#
# Restrict this key to HTTP referrers (localhost + production origins). VITE_* values ship in the client bundle — never commit real keys.
# Production: add https://trafficcontrolrental.com/* and https://www.trafficcontrolrental.com/* if you use www.
VITE_GOOGLE_MAPS_API_KEY=

# Sign in with Google (Google Identity Services). OAuth client type must be **Web application**.
# In Google Cloud Console → APIs & Services → Credentials → your Web client → **Authorized JavaScript origins**,
# add the **exact** origin (scheme + host + port, no path) for every environment:
#   - Local Vite in this repo uses port **3000** (see vite.config.ts): http://localhost:3000
#   - Production: e.g. https://your-app.vercel.app and any custom domain you load the app from
#   - Vercel **preview** URLs each have their own hostname; add each preview origin you test with, or use production only.
# If origins are missing, the browser console shows GSI_LOGGER "origin is not allowed" / gsi/button 403.
VITE_GOOGLE_CLIENT_ID=

# Optional: Map ID from Google Cloud → Map Management (vector map). If unset, the app uses DEMO_MAP_ID for local dev (same idea as <gmp-map map-id="DEMO_MAP_ID">).
# VITE_GOOGLE_MAPS_MAP_ID=
